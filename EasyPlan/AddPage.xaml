<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="EasyPlan.AddPage"
    Title="Add Class"
    BackgroundColor="#111111">

	<ScrollView>
		<VerticalStackLayout Padding="20" Spacing="18">

			<!-- Header -->
			<Grid ColumnDefinitions="Auto,*">
				<Button Text="←"
                        BackgroundColor="Transparent"
                        TextColor="#1E88FF"
                        FontSize="24"
                        Clicked="OnBackClicked"
                        WidthRequest="50" />

				<Label Grid.Column="1"
                       Text="New Class"
                       TextColor="White"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
			</Grid>

			<!-- Class Title -->
			<VerticalStackLayout Spacing="6">
				<Label Text="Class Title"
                       TextColor="White"
                       FontSize="16" />
				<Border BackgroundColor="#2A2A2A"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
					<Entry x:Name="subjectEntry"
                           Placeholder="Enter class title..."
                           PlaceholderColor="Gray"
                           TextColor="White"
                           BackgroundColor="Transparent" />
				</Border>
			</VerticalStackLayout>

			<!-- Date -->
			<VerticalStackLayout Spacing="6">
				<Label Text="Class Date"
                       TextColor="White"
                       FontSize="16" />
				<Border BackgroundColor="#2A2A2A"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
					<DatePicker x:Name="datePicker"
                                TextColor="White"
                                BackgroundColor="Transparent" />
				</Border>
			</VerticalStackLayout>

			<!-- Time -->
			<VerticalStackLayout Spacing="6">
				<Label Text="Class Time"
                       TextColor="White"
                       FontSize="16" />
				<Border BackgroundColor="#2A2A2A"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
					<TimePicker x:Name="timePicker"
                                TextColor="White"
                                BackgroundColor="Transparent" />
				</Border>
			</VerticalStackLayout>

			<!-- Location -->
			<VerticalStackLayout Spacing="6">
				<Label Text="Location"
                       TextColor="White"
                       FontSize="16" />
				<Border BackgroundColor="#2A2A2A"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
					<Entry x:Name="locationEntry"
                           Placeholder="Enter location..."
                           PlaceholderColor="Gray"
                           TextColor="White"
                           BackgroundColor="Transparent" />
				</Border>
			</VerticalStackLayout>

			<!-- Color Selection -->
			<VerticalStackLayout Spacing="6">
				<Label Text="Class Color"
                       TextColor="White"
                       FontSize="16" />

				<Border BackgroundColor="#2A2A2A"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">

					<HorizontalStackLayout Spacing="12">

						<Button x:Name="redBtn"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="#FF5252"
                                Clicked="OnColorSelected" />

						<Button x:Name="blueBtn"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="#1E88FF"
                                Clicked="OnColorSelected" />

						<Button x:Name="greenBtn"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="#4CD964"
                                Clicked="OnColorSelected" />

						<Button x:Name="orangeBtn"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="#FF9800"
                                Clicked="OnColorSelected" />

						<Button x:Name="purpleBtn"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="#A855F7"
                                Clicked="OnColorSelected" />

					</HorizontalStackLayout>

				</Border>
			</VerticalStackLayout>

			<!-- Description -->
			<VerticalStackLayout Spacing="6">
				<Label Text="Description"
                       TextColor="White"
                       FontSize="16" />
				<Border BackgroundColor="#2A2A2A"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
					<Editor x:Name="descriptionEditor"
                            Placeholder="Add notes or details..."
                            PlaceholderColor="Gray"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            AutoSize="TextChanges"
                            HeightRequest="120" />
				</Border>
			</VerticalStackLayout>

			<!-- Save Button -->
			<Button Text="Save"
                    BackgroundColor="#1E88FF"
                    TextColor="White"
                    FontSize="22"
                    FontAttributes="Bold"
                    HeightRequest="60"
                    CornerRadius="16"
                    Clicked="OnSaveClicked" />

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>