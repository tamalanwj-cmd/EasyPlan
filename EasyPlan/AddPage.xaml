<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="EasyPlan.AddPage"
    Title="My Schedule"
    BackgroundColor="#111111">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Page Title -->
            <Label Text="My Schedule"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <!-- Subject -->
            <Entry x:Name="subjectEntry"
                   Placeholder="Subject"
                   TextColor="White"
                   PlaceholderColor="Gray"
                   BackgroundColor="#1E1E1E" />

            <!-- Location -->
            <Entry x:Name="locationEntry"
                   Placeholder="Location"
                   TextColor="White"
                   PlaceholderColor="Gray"
                   BackgroundColor="#1E1E1E" />

            <!-- Date -->
            <DatePicker x:Name="datePicker"
                        TextColor="White"
                        BackgroundColor="#1E1E1E" />

            <!-- Time -->
            <TimePicker x:Name="timePicker"
                        TextColor="White"
                        BackgroundColor="#1E1E1E" />

            <!-- Description -->
            <Editor x:Name="descriptionEditor"
                    Placeholder="Description"
                    TextColor="White"
                    PlaceholderColor="Gray"
                    BackgroundColor="#1E1E1E"
                    HeightRequest="100" />

            <!-- Color Selection -->
            <Label Text="Choose Color"
                   TextColor="White"
                   FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="10">

                <Button x:Name="redBtn"
                        BackgroundColor="Red"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Clicked="OnColorSelected"/>

                <Button x:Name="blueBtn"
                        BackgroundColor="#1E88FF"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Clicked="OnColorSelected"/>

                <Button x:Name="greenBtn"
                        BackgroundColor="Green"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Clicked="OnColorSelected"/>

                <Button x:Name="orangeBtn"
                        BackgroundColor="Orange"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Clicked="OnColorSelected"/>

                <Button x:Name="purpleBtn"
                        BackgroundColor="Purple"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Clicked="OnColorSelected"/>

            </HorizontalStackLayout>

            <!-- Save Button -->
            <Button Text="Save"
                    BackgroundColor="#1E88FF"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="50"
                    Clicked="OnSaveClicked" />

            <!-- Back Button -->
            <Button Text="Back"
                    BackgroundColor="Gray"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="50"
                    Clicked="OnBackClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>