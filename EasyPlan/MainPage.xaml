<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="EasyPlan.MainPage"
    Title="Home"
    BackgroundColor="#111111">

    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="18">

                <!-- Header -->
                <Label Text="Today's Schedule"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"
                       Margin="0,10,0,10" />

                <!-- Dynamic class list -->
                <CollectionView x:Name="scheduleList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{Binding CardColor}"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="15"
                                    Margin="0,0,0,14">

                                <VerticalStackLayout Spacing="6">

                                    <!-- Date -->
                                    <Label Text="{Binding Date}"
                                           TextColor="White"
                                           FontSize="13"
                                           Opacity="0.95" />

                                    <!-- Time -->
                                    <Label Text="{Binding Time}"
                                           TextColor="White"
                                           FontSize="14"
                                           Opacity="0.95" />

                                    <!-- Subject -->
                                    <Label Text="{Binding Subject}"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="22" />

                                    <!-- Location -->
                                    <Label Text="{Binding Location}"
                                           TextColor="White"
                                           FontSize="15" />

                                    <!-- Description -->
                                    <Label Text="{Binding Description}"
                                           TextColor="White"
                                           FontSize="13"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />

                                    <!-- Delete button -->
                                    <Button Text="Delete"
                                            BackgroundColor="#D32F2F"
                                            TextColor="White"
                                            FontSize="14"
                                            CornerRadius="12"
                                            HeightRequest="40"
                                            Margin="0,8,0,0"
                                            Clicked="OnDeleteClicked"
                                            CommandParameter="{Binding .}" />

                                </VerticalStackLayout>

                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Floating Add Button -->
        <Button Text="+"
                WidthRequest="65"
                HeightRequest="65"
                CornerRadius="32"
                BackgroundColor="#1E88FF"
                TextColor="White"
                FontSize="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,20"
                Clicked="GoToAddPage" />

    </Grid>
</ContentPage>