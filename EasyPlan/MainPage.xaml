<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="EasyPlan.MainPage"
    Title="Home"
    BackgroundColor="#1E1E1E">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="18">

                <Label Text="Today"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="White" />

                <Label Text="Monday, 3 March 2026"
                       FontSize="16"
                       TextColor="LightGray" />

                <Label Text="Today's Schedule"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       Margin="0,10,0,0" />

                <Border BackgroundColor="#5DA9FF"
                        StrokeShape="RoundRectangle 14"
                        Padding="15">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="8:30 - 10:30"
                               TextColor="White"
                               FontSize="14" />
                        <Label Text="INF2060 Lecture"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="22" />
                        <Label Text="Room 201"
                               TextColor="White"
                               FontSize="16" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#50D37F"
                        StrokeShape="RoundRectangle 14"
                        Padding="15">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="12:30 - 14:30"
                               TextColor="White"
                               FontSize="14" />
                        <Label Text="SENG2130 Lecture"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="22" />
                        <Label Text="Room 303"
                               TextColor="White"
                               FontSize="16" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FF9800"
                        StrokeShape="RoundRectangle 14"
                        Padding="15">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="16:30 - 18:30"
                               TextColor="White"
                               FontSize="14" />
                        <Label Text="SENG2260 Lab"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="22" />
                        <Label Text="Lab 3"
                               TextColor="White"
                               FontSize="16" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="Urgent Tasks"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#FF5C5C"
                       Margin="0,10,0,0" />

                <Border BackgroundColor="#2A2A2A"
                        Stroke="#3A3A3A"
                        StrokeShape="RoundRectangle 10"
                        Padding="15">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="☐ Prepare Presentation (Due today)"
                               TextColor="White"
                               FontSize="16" />
                        <Label Text="☑ Read Chapter 2"
                               TextColor="Gray"
                               FontSize="16" />
                        <Label Text="☐ Homework (Tomorrow)"
                               TextColor="White"
                               FontSize="16" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Button Text="+"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                BackgroundColor="#1E88FF"
                TextColor="White"
                FontSize="28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,20"
                Clicked="GoToAddPage" />
    </Grid>
</ContentPage>